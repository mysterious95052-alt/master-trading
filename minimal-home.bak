<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Market Vision — Master Smart Money Concepts, CRT & 4H Candle Range Strategy. Premium trading education for aspiring institutional-level traders.">
    <meta name="keywords" content="trading education, SMC, smart money concepts, CRT strategy, 4H candle range, forex, trading course">
    <meta name="author" content="Market Vision Education">
    <meta name="theme-color" content="#050508">
    <title>Market Vision | Premium Trading Education</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="css/styles.css">
</head>
<body>
    <canvas id="particle-canvas"></canvas>

    <nav id="main-nav" class="nav">
        <div class="nav__container">
            <a href="/" class="nav__logo">
                <img src="images/logo.png" alt="Market Vision Logo" class="nav__logo-img">
                Market<span>Vision</span>
            </a>
            <div class="nav__links" id="nav-links">
                <a href="pages/the-edge.html" class="nav__link" onclick="closeMobileMenu()">The Edge</a>
                <a href="pages/programs.html" class="nav__link" onclick="closeMobileMenu()">Programs</a>
                <a href="pages/results.html" class="nav__link" onclick="closeMobileMenu()">Results</a>
                <a href="pages/mentor.html" class="nav__link" onclick="closeMobileMenu()">Mentor</a>
                <a href="pages/faq.html" class="nav__link" onclick="closeMobileMenu()">FAQ</a>
            </div>
            <a href="pages/apply.html" class="nav__cta">Get Instant Access</a>
            <button class="nav__hamburger" id="hamburger-btn" onclick="toggleMobileMenu()" aria-label="Toggle menu">
                <span></span><span></span><span></span>
            </button>
        </div>
    </nav>

    <section id="hero" class="hero">
        <div class="hero__glow hero__glow--1"></div>
        <div class="hero__glow hero__glow--2"></div>
        <div class="hero__content">
            <div class="hero__badge reveal-up">
                <i class="fa-solid fa-bolt"></i>
                <span>🔥 Limited Seats — Only 50 Left | Price Increasing Soon</span>
            </div>
            <h1 class="hero__title reveal-up" style="--delay: 0.1s;">
                Learn How <span class="text-gold-gradient">Smart Money</span><br>
                Trades the Market
            </h1>
            <p class="hero__subtitle reveal-up" style="--delay: 0.2s;">
                After this course, you will be able to capture <strong>high RRR trades</strong> using Smart Money Concepts (SMC). Build a high-performance trading system and stop being retail liquidity.
            </p>
            <div class="hero__actions reveal-up" style="--delay: 0.3s;">
                <a href="pages/apply.html" class="btn btn--primary btn--lg btn--glow">
                    <span>Enroll in Mentorship</span>
                    <i class="fa-solid fa-arrow-right"></i>
                </a>
                <a href="pages/programs.html" class="btn btn--glass btn--lg">
                    <span>Get Instant Access</span>
                </a>
            </div>
            <div class="hero__trust reveal-up" style="--delay: 0.4s;">
                <div class="hero__trust-item"><i class="fa-solid fa-shield-halved"></i><span>Verified Mentor</span></div><div class="hero__trust-divider"></div>
                <div class="hero__trust-item"><i class="fa-solid fa-graduation-cap"></i><span>1000+ Traders Trained</span></div><div class="hero__trust-divider"></div>
                <div class="hero__trust-item"><i class="fa-solid fa-star"></i><span>4.9/5 Rating</span></div><div class="hero__trust-divider"></div>
                <div class="hero__trust-item"><i class="fa-solid fa-lock"></i><span>Secure Payment</span></div>
            </div>
        </div>
    </section>

    <!-- ============================================ -->
    <!-- FOOTER                                        -->
    <!-- ============================================ -->
    <footer class="footer">
        <div class="footer__container">
            <div class="footer__top">
                <div class="footer__brand">
                    <a href="/" class="footer__logo">Market<span>Vision</span></a>
                    <p class="footer__tagline">Master institutional trading. Stop being retail liquidity.</p>
                    <div class="footer__socials">
                        <a href="#" class="footer__social" aria-label="Telegram"><i class="fa-brands fa-telegram"></i></a>
                        <a href="#" class="footer__social" aria-label="YouTube"><i class="fa-brands fa-youtube"></i></a>
                        <a href="#" class="footer__social" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
                        <a href="#" class="footer__social" aria-label="Twitter"><i class="fa-brands fa-x-twitter"></i></a>
                    </div>
                </div>
                <div class="footer__links-group">
                    <h4 class="footer__links-title">Programs</h4>
                    <a href="pages/programs.html" class="footer__link">SMC Mastery</a>
                    <a href="pages/programs.html" class="footer__link">CRT Strategy</a>
                    <a href="pages/programs.html" class="footer__link">4H Candle Range</a>
                </div>
                <div class="footer__links-group">
                    <h4 class="footer__links-title">Company</h4>
                    <a href="pages/the-edge.html" class="footer__link">The Edge</a>
                    <a href="pages/results.html" class="footer__link">Student Results</a>
                    <a href="pages/faq.html" class="footer__link">FAQ</a>
                    <a href="pages/apply.html" class="footer__link">Apply Now</a>
                </div>
                <div class="footer__links-group">
                    <h4 class="footer__links-title">Legal</h4>
                    <a href="#" class="footer__link">Privacy Policy</a>
                    <a href="#" class="footer__link">Terms of Service</a>
                    <a href="#" class="footer__link">Refund Policy</a>
                </div>
            </div>
            <div class="footer__bottom">
                <p>© 2024 Market Vision Education. All rights reserved.</p>
                <p class="footer__disclaimer">Trading in financial markets involves significant risk. Past results do not guarantee future performance. This is an educational program, not financial advice.</p>
            </div>
        </div>
    </footer>

    <script src="js/main.js"></script>
</body>
</html>
